{
  "name": "openclaw-exec-truncate",
  "version": "1.0.1",
  "description": "Domain-aware output truncation for exec tool — compresses git diff/log, grep, ls, and build output to reduce token consumption",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "openclaw": "^2026.4.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "token-optimization",
    "exec",
    "truncation"
  ],
  "dependencies": {
    "estree-walker": "^3.0.3"
  }
}
